"use client";

import { useTranslations } from 'next-intl';
import { Link } from '@/i18n/navigation';
"use client";

import { useState, useRef, useCallback } from "react";
import imageCompression from "browser-image-compression";

interface FileInfo {
  name: string;
  originalSize: number;
  compressedSize: number;
  originalUrl: string;
  compressedUrl: string;
  originalDimensions: string;
  compressedDimensions: string;
}

function formatBytes(bytes: number) {
  if (bytes < 1024) return bytes + " B";
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + " KB";
  return (bytes / (1024 * 1024)).toFixed(2) + " MB";
}

export default function ImageCompressorPage() {
  const [quality, setQuality] = useState(0.8);
  const [maxWidth, setMaxWidth] = useState(1920);
  const [results, setResults] = useState<FileInfo[]>([]);
  const [processing, setProcessing] = useState(false);
  const inputRef = useRef<HTMLInputElement>(null);

  const getImageDimensions = (file: File | Blob): Promise<string> =>
    new Promise((resolve) => {
      const img = new Image();
      img.onload = () => resolve(`${img.width}×${img.height}`);
      img.src = URL.createObjectURL(file);
    });

  const compress = useCallback(async (files: FileList) => {
    setProcessing(true);
    const newResults: FileInfo[] = [];

    for (const file of Array.from(files)) {
      try {
        const originalUrl = URL.createObjectURL(file);
        const originalDimensions = await getImageDimensions(file);

        const compressed = await imageCompression(file, {
          maxSizeMB: 10,
          maxWidthOrHeight: maxWidth,
          useWebWorker: true,
          initialQuality: quality,
        });

        const compressedUrl = URL.createObjectURL(compressed);
        const compressedDimensions = await getImageDimensions(compressed);

        newResults.push({
          name: file.name,
          originalSize: file.size,
          compressedSize: compressed.size,
          originalUrl,
          compressedUrl,
          originalDimensions,
          compressedDimensions,
        });
      } catch (e) {
        console.error(e);
      }
    }

    setResults((prev) => [...newResults, ...prev]);
    setProcessing(false);
  }, [quality, maxWidth]);

  const onDrop = useCallback((e: React.DragEvent) => {
    e.preventDefault();
    if (e.dataTransfer.files.length > 0) compress(e.dataTransfer.files);
  }, [compress]);

  return (
    <div className="min-h-screen bg-gray-50">
      <div className="container mx-auto px-4 py-8 max-w-4xl">
        <a href="/" className="text-blue-600 hover:underline mb-4 inline-block">← Back to Home</a>
        <h1 className="text-4xl font-bold text-gray-900 mb-2">Image Compressor</h1>
        <p className="text-gray-600 mb-8">Compress JPG and PNG images while maintaining quality</p>

        <div className="bg-white rounded-lg shadow p-6 mb-6">
          <div className="grid grid-cols-2 gap-6 mb-6">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-2">Quality: {Math.round(quality * 100)}%</label>
              <input type="range" min={0.1} max={1} step={0.05} value={quality} onChange={(e) => setQuality(+e.target.value)} className="w-full" />
            </div>
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-2">Max Width: {maxWidth}px</label>
              <input type="range" min={320} max={4096} step={160} value={maxWidth} onChange={(e) => setMaxWidth(+e.target.value)} className="w-full" />
            </div>
          </div>

          <div
            onDrop={onDrop}
            onDragOver={(e) => e.preventDefault()}
            onClick={() => inputRef.current?.click()}
            className="border-2 border-dashed border-gray-300 rounded-lg p-12 text-center cursor-pointer hover:border-blue-400 hover:bg-blue-50 transition-colors"
          >
            <div className="text-4xl mb-3">🖼️</div>
            <p className="text-gray-600 font-medium">Drop images here or click to upload</p>
            <p className="text-gray-400 text-sm mt-1">JPG, PNG, WebP — up to 20MB each</p>
            <input ref={inputRef} type="file" accept="image/*" multiple className="hidden"
              onChange={(e) => e.target.files && compress(e.target.files)} />
          </div>

          {processing && (
            <div className="mt-4 text-center text-blue-600 font-medium">Compressing...</div>
          )}
        </div>

        {results.length > 0 && (
          <div className="space-y-4">
            {results.map((r, i) => {
              const savings = ((1 - r.compressedSize / r.originalSize) * 100).toFixed(1);
              return (
                <div key={i} className="bg-white rounded-lg shadow p-5">
                  <div className="flex items-start gap-4">
                    <img src={r.compressedUrl} alt={r.name} className="w-20 h-20 object-cover rounded-lg shrink-0" />
                    <div className="flex-1 min-w-0">
                      <p className="font-medium text-gray-800 truncate mb-2">{r.name}</p>
                      <div className="grid grid-cols-3 gap-4 text-sm">
                        <div>
                          <p className="text-gray-500">Original</p>
                          <p className="font-semibold">{formatBytes(r.originalSize)}</p>
                          <p className="text-xs text-gray-400">{r.originalDimensions}</p>
                        </div>
                        <div>
                          <p className="text-gray-500">Compressed</p>
                          <p className="font-semibold text-green-600">{formatBytes(r.compressedSize)}</p>
                          <p className="text-xs text-gray-400">{r.compressedDimensions}</p>
                        </div>
                        <div>
                          <p className="text-gray-500">Saved</p>
                          <p className="font-semibold text-blue-600">{savings}%</p>
                        </div>
                      </div>
                    </div>
                    <a href={r.compressedUrl} download={`compressed-${r.name}`}
                      className="shrink-0 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm">
                      Download
                    </a>
                  </div>
                </div>
              );
            })}
          </div>
        )}
      </div>
    </div>
  );
}
